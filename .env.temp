# ── LLM ──────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://192.168.2.18:11434/v1
OLLAMA_ENDPOINT_1=http://192.168.2.18:11434/api/generate
OLLAMA_ENDPOINT_2=http://192.168.2.18:11434/api/chat
# model เล็ก — ใช้ตอบ user (เร็ว)
MODEL_NAME=qwen2.5:3b

# model ใหญ่ — ใช้สร้าง SQL (แม่น)
# pull ก่อนใช้: ollama pull qwen2.5:3b
SQL_MODEL=qwen2.5-coder:3b

LLM_TIMEOUT=120

# ── Database (REQUIRED — ไม่มี default) ──────────────────────────────────────
DB_SERVER=192.168.2.201
DB_NAME=lspdata
DB_USER=sa
DB_PASS=1234
DB_DRIVER=SQL Server Native Client 10.0
DB_TIMEOUT=30

# ── Security ──────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://192.168.2.201:3000
RATE_LIMIT_REQ=30   # requests ต่อ window
RATE_LIMIT_WIN=60   # window size (seconds)


