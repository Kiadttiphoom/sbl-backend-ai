# ── LLM ──────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://IP:11434/v1
OLLAMA_ENDPOINT_1=http://IP:11434/api/generate
OLLAMA_ENDPOINT_2=http://IP:11434/api/chat
MODEL_NAME=qwen2.5-coder:7b
SQL_MODEL=qwen2.5-coder:7b
LLM_TIMEOUT=300

# ── Database (REQUIRED — ไม่มี default) ──────────────────────────────────────

# ── Lspdata
DB_NAME_LSPDATA=DB_NAME
DB_SERVER_LSPDATA=IP
DB_USER_LSPDATA=USER
DB_PASS_LSPDATA=PASS
DB_DRIVER_LSPDATA=SQL Server Native Client 10.0
DB_TIMEOUT_LSPDATA=30

# ── crms
DB_NAME_CRMS=DB_NAME
DB_SERVER_CRMS=IP
DB_USER_CRMS=USER
DB_PASS_CRMS=PASS
DB_DRIVER_CRMS=SQL Server Native Client 10.0
DB_TIMEOUT_CRMS=30

# ── Security ──────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://ip:port,http://ip:port
RATE_LIMIT_REQ=30
RATE_LIMIT_WIN=60
