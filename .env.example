# ── LLM ──────────────────────────────────────────────────────────────────────
OLLAMA_ENDPOINT_1=http://ip:port/api/generate
OLLAMA_ENDPOINT_2=http://ip:port/api/chat
# model เล็ก — ใช้ตอบ user (เร็ว)
MODEL_NAME=qwen2.5:3b

# model ใหญ่ — ใช้สร้าง SQL (แม่น)
# pull ก่อนใช้: ollama pull qwen2.5:3b
SQL_MODEL=qwen2.5-coder:3b

LLM_TIMEOUT=120

# ── Database (REQUIRED — ไม่มี default) ──────────────────────────────────────
DB_SERVER=IP
DB_NAME=DB_NAME
DB_USER=DB_USER
DB_PASS=DB_PASS
DB_DRIVER=SQL Server Native Client 10.0
DB_TIMEOUT=30

# ── Security Front End──────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://http://ip:port,http:/http://ip:port,http://http://ip:port
RATE_LIMIT_REQ=30   # requests ต่อ window
RATE_LIMIT_WIN=60   # window size (seconds)
